# Microsoft 365 Mail Service
M365_CLIENT_ID=your-azure-app-client-id
M365_CLIENT_SECRET=your-azure-app-client-secret
M365_TENANT_ID=your-azure-tenant-id
M365_REDIRECT_URI=http://your-server-ip:8010/auth/callback
M365_SCOPES=Mail.Read User.Read offline_access
M365_DB_PATH=/app/data/mailboxes.sqlite3
